# =====================================================================
# SonicForge — Example environment file
# Copy this file to `.env` and fill in the values for your own deployment.
# Do NOT commit your real .env file to git.
# =====================================================================

# ---------------------------------------------------------------------
# Supabase (database, auth, storage)
# ---------------------------------------------------------------------
# Create a free project at https://supabase.com → Project Settings → API.
# The PUBLISHABLE / ANON key is safe to expose in the browser.
# The SERVICE_ROLE key is SERVER-ONLY — never expose to the client.

# Public values (also exposed to the browser bundle via Vite)
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-side mirrors of the same values (used by server functions / SSR)
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# SECRET — service role key (bypasses RLS, used by admin server code & webhooks)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional — only needed if you run `supabase` CLI migrations locally
# SUPABASE_DB_URL="postgresql://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"

# ---------------------------------------------------------------------
# VPS Agent (runs the actual Highrise bot processes)
# ---------------------------------------------------------------------
# The web app talks to a small Node agent (see vps-agent/ folder) that
# spawns / stops bot processes on your server.
#
# VPS_AGENT_URL    = public HTTPS URL of your VPS agent
# VPS_AGENT_SECRET = shared secret — also used to verify inbound
#                    /api/public/bank/* and /cron/* calls from the bot
VPS_AGENT_URL="https://your-vps-domain.example.com"
VPS_AGENT_SECRET="generate-a-long-random-string-here"

# ---------------------------------------------------------------------
# Lovable AI Gateway (optional)
# ---------------------------------------------------------------------
# Only needed if you keep the Lovable-hosted AI features. Leave unset
# if you self-host without AI calls.
# LOVABLE_API_KEY=""

# ---------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------
NODE_ENV="production"
# Port the SSR server listens on (most hosts inject this automatically)
# PORT=3000
